{
	"include": ["src/index.ts", "custom.d.ts", "node_modules/pixi-spine/dist/pixi-spine.d.ts"],
	"exclude": [".git", "node_modules"],
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"importHelpers": true,
		"lib": ["DOM", "ES2019"],
		"module": "ES2015",
		"moduleResolution": "node",
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"noUnusedLocals": false,
		"outDir": "./dts",
		"resolveJsonModule": true,
		"sourceMap": true,
		"strict": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"target": "ES5"
	}
}
